{
  "packages/*/{package.json,tsconfig.json}": [
    "ts-node ./bin/validate-publish-imports.ts --fix",
    "yarn sync:tsconfig-references"
  ],
  "**/*.{js,mjs,jsx,ts,tsx,md,json,yml,yaml}": "oxfmt --no-error-on-unmatched-pattern",
  "**/*.{js,mjs,jsx,ts,tsx}": "oxlint --fix --type-aware --quiet"
}
