#!/bin/bash -e

# Builds the web app in "capacitor" mode and syncs it into a native mobile
# project (packages/mobile/{ios,android}). Mirrors bin/package-browser, but
# targets the Capacitor wrapper instead of the standalone web build.
#
# Usage: bin/package-mobile <ios|android> [--skip-translations]
#
# Requires (not installed by yarn):
#   - ios:     Xcode + CocoaPods (macOS only)
#   - android: JDK 17 + the Android SDK

ROOT=`dirname $0`

cd "$ROOT/.."

PLATFORM=""
SKIP_TRANSLATIONS=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    ios|android)
      PLATFORM="$1"
      shift
      ;;
    --skip-translations)
      SKIP_TRANSLATIONS=true
      shift
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

if [ -z "$PLATFORM" ]; then
  echo "Usage: bin/package-mobile <ios|android> [--skip-translations]" >&2
  exit 1
fi

if [ "$SKIP_TRANSLATIONS" = false ]; then
  echo "Updating translations..."
  if ! [ -d packages/desktop-client/locale ]; then
      git clone https://github.com/actualbudget/translations packages/desktop-client/locale
  fi
  pushd packages/desktop-client/locale > /dev/null
  git checkout .
  git pull
  popd > /dev/null
  packages/desktop-client/bin/remove-untranslated-languages
fi

# Build the capacitor-flavoured web bundle (browser bundle, no service worker,
# served from the native custom scheme root).
lage build:browser:capacitor --to=@actual-app/web

# Stage the build into the capacitor webDir and sync into the native project.
yarn workspace @actual-app/mobile "sync:$PLATFORM"
