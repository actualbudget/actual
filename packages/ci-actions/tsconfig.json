{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["vite/client", "node"],
    "outDir": "dist",
    "rootDir": ".",
    "plugins": [{ "name": "typescript-strict-plugin", "paths": ["."] }]
  },
  "include": ["src/**/*", "bin/**/*"],
  "exclude": ["node_modules"]
}
