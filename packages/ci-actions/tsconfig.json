{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "composite": true
  },
  "include": ["src/**/*", "bin/**/*"],
  "exclude": ["node_modules"]
}
