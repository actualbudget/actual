{
  "name": "@actual-app/ios",
  "version": "26.5.2",
  "private": true,
  "description": "Native iOS app for Actual Budget (Capacitor wrapper around the web build)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actualbudget/actual.git",
    "directory": "packages/desktop-ios"
  },
  "scripts": {
    "build:web": "yarn workspace @actual-app/web build:browser:capacitor",
    "copy-web": "node ./bin/stage-webdir.mjs",
    "sync": "yarn copy-web && cap sync ios",
    "build": "yarn build:web && yarn sync",
    "add:ios": "cap add ios",
    "open": "cap open ios",
    "run:ios": "yarn sync && cap run ios"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0"
  }
}
