{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    // Using ES2021 because that's the newest version where
    // the latest Node 16.x release supports all of the features
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "declarationDir": "@types",
    "rootDir": ".",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "paths": {
      "loot-core/*": ["../loot-core/lib-dist/decl/src/*"]
    },
    "plugins": [{ "name": "typescript-strict-plugin", "paths": ["."] }]
  },
  "references": [{ "path": "../crdt" }, { "path": "../loot-core" }],
  "include": [
    "index.ts",
    "methods.ts",
    "utils.ts",
    "injected.js",
    "validateNodeVersion.js",
    "vitest.config.ts",
    "app/query.js",
    "migrations/**/*",
    "bin/**/*",
    "mocks/**/*"
  ],
  "exclude": [
    "**/node_modules/**",
    "dist",
    "**/dist/**",
    "@types",
    "**/@types/**",
    "*.test.ts"
  ]
}
