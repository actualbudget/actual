{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "strict": false, // TODO: fix issues and remove this
    "emitDeclarationOnly": true,
    "outDir": "build/ts",
    "rootDir": ".",
    "tsBuildInfoFile": "build/ts/.tsbuildinfo",
    "customConditions": ["electron-renderer"],
    "paths": {
      "@actual-app/shared-types/*": ["../shared-types/src/*"]
    },
    "plugins": [
      {
        "name": "typescript-strict-plugin",
        "paths": ["."]
      }
    ]
  },
  "references": [
    {
      "path": "../component-library"
    },
    {
      "path": "../loot-core"
    },
    {
      "path": "../plugins-core"
    },
    {
      "path": "../shared-types"
    },
    {
      "path": "../plugins-service"
    }
  ],
  "include": ["**/*.ts", "src/**/*.tsx", "src/**/*.js"],
  "exclude": ["node_modules", "build", "**/service-worker/**", "e2e"]
}
