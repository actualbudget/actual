{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    // window.ts lives outside this dir, so root the project at packages/ to keep
    // it within rootDir (noEmit, so this only affects rootDir validation).
    "rootDir": "../..",
