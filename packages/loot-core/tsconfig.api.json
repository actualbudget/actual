{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowJs": false,
    "noEmit": false,
    "outDir": "lib-dist/decl-api",
    "tsBuildInfoFile": "lib-dist/decl-api/.tsbuildinfo"
  },
  "references": [{ "path": "." }],
  "include": ["./typings", "./src/server/*"],
  "exclude": [
    "**/node_modules/*",
    "**/build/*",
    "**/lib-dist/*",
    "./src/server/bench.ts"
  ]
}
