{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "printWidth": 80,
  "experimentalSortImports": {
    "groups": [
      "react",
      "value-builtin",
      { "newlinesBetween": false },
      "type-builtin",
      "value-external",
      { "newlinesBetween": false },
      "type-external",
      ["value-parent", "value-subpath"],
      { "newlinesBetween": false },
      ["type-parent", "type-subpath"],
      "value-sibling",
      { "newlinesBetween": false },
      "type-sibling",
      "value-index",
      { "newlinesBetween": false },
      "type-index"
    ],
    "customGroups": [
      {
        "groupName": "react",
        "elementNamePattern": ["react", "react-dom/*", "react-*"]
      }
    ],
    "newlinesBetween": true
  }
}
