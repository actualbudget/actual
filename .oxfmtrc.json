{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "printWidth": 80,
  "experimentalSortImports": {
    "groups": [
      "react",
      "builtin",
      "external",
      "loot-core",
      ["parent", "subpath"],
      "sibling",
      "index"
    ],
    "customGroups": [
      {
        "groupName": "react",
        "elementNamePattern": ["react", "react-dom/*", "react-*"]
      },
      {
        "groupName": "loot-core",
        "elementNamePattern": ["loot-core/**", "@actual-app/core/**"]
      }
    ],
    "newlinesBetween": true
  }
}
